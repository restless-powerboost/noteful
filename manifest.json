{
  "manifest_version": 3,
  "name": "Noteful",
  "version": "1.0.0",
  "description": "Sticky Notes auf jeder Website — verschiebbar, skalierbar, Markdown, Reminder, Sync.",
  "permissions": ["storage", "activeTab", "notifications", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Noteful",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "create-note": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Neue Notiz erstellen"
    },
    "toggle-all": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Alle Notizen ein-/ausblenden"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["shared.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
